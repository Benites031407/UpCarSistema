# IoT Controller Configuration

# Controller and Machine Identification
CONTROLLER_ID=controller-001
MACHINE_ID=machine-001

# MQTT Broker Configuration
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Hardware Configuration
RELAY_PIN=18
TEMPERATURE_SENSOR_TYPE=DHT22

# Safety Limits
MIN_SAFE_TEMP=0
MAX_SAFE_TEMP=50
CRITICAL_TEMP=60
MAX_ACTIVATION_DURATION_MS=1800000

# Monitoring Intervals (milliseconds)
HEARTBEAT_INTERVAL=60000
TEMPERATURE_INTERVAL=30000

# Logging
LOG_LEVEL=info